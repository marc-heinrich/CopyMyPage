{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "com_copymypage",
  "version": "0.0.10",
  "description": "Asset definitions for CopyMyPage template and related components.",
  "license": "GPL-3.0-or-later",
  "assets": [
    {
      "name": "copymypage.site",
      "type": "preset",
      "dependencies": [
        "template#style",
        "copymypage#script"
      ]
    },
    {
      "name": "template",
      "type": "style",
      "uri": "com_copymypage/template.min.css",
      "version": "0.0.9",
      "dependencies": [
        "uikit",
        "template.fonts"
      ]
    },
    {
      "name": "template.fonts",
      "type": "style",
      "uri": "com_copymypage/fonts-local/fonts-local.min.css"
    },
    {
      "name": "copymypage",
      "type": "script",
      "uri": "com_copymypage/copymypage.min.js",
      "version": "0.0.9",
      "class": "CopyMyPageAssetItem",
      "dependencies": [
        "core",
        "uikit",
        "uikit.icons",
        "copymypage.base",
        "copymypage.behavior",
        "copymypage.onepage"
      ],
      "attributes": {
        "defer": true
      }      
    },
    {
      "name": "copymypage.base",
      "type": "script",
      "uri": "com_copymypage/copymypage-base.min.js",
      "version": "0.0.9",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.behavior",
      "type": "script",
      "uri": "com_copymypage/copymypage-behavior.min.js",
      "version": "0.0.9",
      "dependencies": [
        "copymypage.base"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.onepage",
      "type": "script",
      "uri": "com_copymypage/copymypage-onepage.min.js",
      "version": "0.0.9",
      "dependencies": [
        "copymypage.base"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.dropdown",
      "type": "script",
      "uri": "com_copymypage/copymypage-dropdown.min.js",
      "version": "0.0.10",
      "dependencies": [
        "uikit",
        "copymypage.base"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.mmenu.navigation",
      "type": "script",
      "uri": "com_copymypage/copymypage-mmenu-navigation.min.js",
      "version": "0.0.10",
      "dependencies": [
        "copymypage.base"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.modal.dialog",
      "type": "script",
      "uri": "com_copymypage/copymypage-dialog.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "uikit"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.modal.alert",
      "type": "script",
      "uri": "com_copymypage/copymypage-alert.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "uikit",
        "copymypage.modal.dialog"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.modal.confirm",
      "type": "script",
      "uri": "com_copymypage/copymypage-confirm.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "uikit",
        "copymypage.modal.dialog"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.modal.prompt",
      "type": "script",
      "uri": "com_copymypage/copymypage-prompt.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "uikit",
        "copymypage.modal.dialog"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.modal.dialogs",
      "type": "script",
      "uri": "com_copymypage/copymypage-modal-dialogs.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "messages",
        "uikit",
        "copymypage.modal.dialog",
        "copymypage.modal.alert",
        "copymypage.modal.confirm",
        "copymypage.modal.prompt"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "copymypage.dialog",
      "type": "preset",
      "dependencies": [
        "copymypage.modal.dialogs"
      ]
    },
    {
      "name": "copymypage.modal.dev",
      "type": "script",
      "uri": "com_copymypage/dev/copymypage-modal-dev.min.js",
      "version": "0.0.6",
      "dependencies": [
        "core",
        "copymypage.modal.dialogs"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "uikit",
      "type": "style",
      "uri": "com_copymypage/uikit/uikit.min.css",
      "version": "3.25.11"
    },
    {
      "name": "uikit",
      "type": "script",
      "uri": "com_copymypage/uikit/uikit.min.js",
      "version": "3.25.11",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "uikit.icons",
      "type": "script",
      "uri": "com_copymypage/uikit/uikit-icons.min.js",
      "version": "3.25.11",
      "dependencies": [
        "uikit"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "joomla.fontawesome",
      "type": "style",
      "uri": "system/joomla-fontawesome.min.css"
    },
    {
      "name": "mmenu.light",
      "type": "style",
      "uri": "com_copymypage/mmenu-light/mmenu-light.min.css",
      "version": "3.2.2"
    },
    {
      "name": "mmenu.light",
      "type": "script",
      "uri": "com_copymypage/mmenu-light/mmenu-light.min.js",
      "version": "3.2.2",
      "class": "MmenuLightAssetItem",
      "dependencies": [
        "core",
        "mmenu.light.polyfills"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "mmenu.light.polyfills",
      "type": "script",
      "uri": "com_copymypage/mmenu-light/mmenu-light.polyfills.min.js",
      "version": "3.2.2",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "mburger",
      "type": "script",
      "uri": "com_copymypage/mburger/index.min.js",
      "version": "3.1.4",
      "attributes": {
        "type": "module"
      }
    }
  ]
}
